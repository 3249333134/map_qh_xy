{
  "easycom": {
    "autoscan": true,
    "custom": {
      "^ProfileSection$": "@/pages/my/components/ProfileSection.vue",
      "^ContentSection$": "@/pages/my/components/ContentSection.vue",
      "^LocationModule$": "@/pages/my/components/LocationModule.vue",
      "^DateModule$": "@/pages/my/components/DateModule.vue",
      "^FavoriteModule$": "@/pages/my/components/FavoriteModule.vue"
    }
  },
  "pages": [
    {
      "path": "pages/index/index",
